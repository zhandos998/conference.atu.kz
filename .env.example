APP_NAME="Conference ATU"
APP_KEY=base64:replace_with_php_artisan_key_generate_show
APP_URL=https://conference.atu.kz
APP_ENV=production
APP_DEBUG=false

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=conference
DB_USERNAME=conference
DB_PASSWORD=change_me_to_a_long_random_password

FRONTEND_URL=https://conference.atu.kz
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8094
TRUSTED_PROXIES=*
PHPMYADMIN_PORT=8095
PHPMYADMIN_UPLOAD_LIMIT=64M

MYSQL_DATABASE=conference
MYSQL_USER=conference
MYSQL_PASSWORD=change_me_to_a_long_random_password
MYSQL_ROOT_PASSWORD=change_me_to_a_long_random_root_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=conference@atu.edu.kz
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
